<Window x:Class="PetStoreDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetStoreDesktop"
        xmlns:vm="clr-namespace:PetStoreDesktop.ViewModels"
        xmlns:conv="clr-namespace:PetStoreDesktop.Converters"
        mc:Ignorable="d"
        Title="Система управління зоомагазином"
        Height="750"
        Width="1300"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:BooleanToLoadingTextConverter x:Key="BooleanToLoadingTextConverter"/>
    </Window.Resources>

    <Grid>
        <TabControl>
            <!-- ДАШБОРД -->
            <TabItem Header="📊 Дашборд"
                     x:Name="DashboardTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Статистика та аналітика"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <!-- Картки статистики -->
                    <UniformGrid Grid.Row="1"
                                 Rows="1"
                                 Columns="5"
                                 Margin="0,0,0,20">
                        <Border Background="#2196F3"
                                Margin="5"
                                Padding="15"
                                CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="Товарів"
                                           Foreground="White"
                                           FontSize="14"/>
                                <TextBlock Text="{Binding TotalProducts}"
                                           Foreground="White"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#4CAF50"
                                Margin="5"
                                Padding="15"
                                CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="Тварин"
                                           Foreground="White"
                                           FontSize="14"/>
                                <TextBlock Text="{Binding TotalAnimals}"
                                           Foreground="White"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FF9800"
                                Margin="5"
                                Padding="15"
                                CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="Замовлень"
                                           Foreground="White"
                                           FontSize="14"/>
                                <TextBlock Text="{Binding TotalOrders}"
                                           Foreground="White"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#9C27B0"
                                Margin="5"
                                Padding="15"
                                CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="Дохід"
                                           Foreground="White"
                                           FontSize="14"/>
                                <TextBlock Text="{Binding TotalRevenue, StringFormat={}{0:C}}"
                                           Foreground="White"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F44336"
                                Margin="5"
                                Padding="15"
                                CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="Низький запас"
                                           Foreground="White"
                                           FontSize="14"/>
                                <TextBlock Text="{Binding LowStockCount}"
                                           Foreground="White"
                                           FontSize="32"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Деталі -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Товари з низьким запасом"
                                  Margin="0,0,10,0">
                            <DataGrid ItemsSource="{Binding LowStockProducts}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Товар"
                                                        Binding="{Binding ProductName}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Залишок"
                                                        Binding="{Binding QuantityInStock}"
                                                        Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="1"
                                  Header="Останні замовлення"
                                  Margin="10,0,0,0">
                            <DataGrid ItemsSource="{Binding RecentOrders}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="№"
                                                        Binding="{Binding OrderID}"
                                                        Width="50"/>
                                    <DataGridTextColumn Header="Клієнт"
                                                        Binding="{Binding CustomerName}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Сума"
                                                        Binding="{Binding TotalAmount, StringFormat={}{0:C}}"
                                                        Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ТОВАРИ -->
            <TabItem Header="📦 Товари"
                     x:Name="ProductsTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопки управління -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Content="🔄 Оновити"
                                Command="{Binding RefreshCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="➕ Додати товар"
                                Command="{Binding AddProductCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="✏️ Редагувати"
                                Command="{Binding EditProductCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="🗑️ Видалити"
                                Command="{Binding DeleteProductCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                    </StackPanel>

                    <!-- Пошук та фільтрація -->
                    <GroupBox Grid.Row="1"
                              Header="Пошук та фільтрація"
                              Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="CategoryName"
                                      Margin="0,0,10,0"/>
                            <Button Grid.Column="2"
                                    Content="Очистити"
                                    Command="{Binding ClearFilterCommand}"
                                    Padding="10,5"/>
                        </Grid>
                    </GroupBox>

                    <!-- Таблиця товарів -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding ProductID}"
                                                Width="50"/>
                            <DataGridTextColumn Header="Назва"
                                                Binding="{Binding ProductName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Ціна"
                                                Binding="{Binding Price, StringFormat={}{0:C}}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Кількість"
                                                Binding="{Binding QuantityInStock}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Категорія"
                                                Binding="{Binding CategoryName}"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StatusBar Grid.Row="3">
                        <TextBlock>
                            <Run Text="Всього товарів: "/>
                            <Run Text="{Binding Products.Count, Mode=OneWay}"
                                 FontWeight="Bold"/>
                        </TextBlock>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- ТВАРИНИ -->
            <TabItem Header="🐾 Тварини"
                     x:Name="AnimalsTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Content="🔄 Оновити"
                                Command="{Binding RefreshCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="➕ Додати тварину"
                                Command="{Binding AddAnimalCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="✏️ Редагувати"
                                Command="{Binding EditAnimalCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="🗑️ Видалити"
                                Command="{Binding DeleteAnimalCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Height="30"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Animals}"
                              SelectedItem="{Binding SelectedAnimal}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding AnimalID}"
                                                Width="50"/>
                            <DataGridTextColumn Header="Ім'я"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Вид"
                                                Binding="{Binding Species}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Порода"
                                                Binding="{Binding Breed}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Вік (міс)"
                                                Binding="{Binding AgeMonths}"
                                                Width="80"/>
                            <DataGridTextColumn Header="Ціна"
                                                Binding="{Binding Price, StringFormat={}{0:C}}"
                                                Width="100"/>
                            <DataGridCheckBoxColumn Header="Вакциновано"
                                                    Binding="{Binding IsVaccinated}"
                                                    Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ЗАМОВЛЕННЯ -->
            <TabItem Header="🛒 Замовлення"
                     x:Name="OrdersTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Content="🔄 Оновити"
                                Command="{Binding RefreshCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="👁 Переглянути"
                                Command="{Binding ViewDetailsCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="📝 Змінити статус"
                                Command="{Binding UpdateStatusCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <DatePicker Grid.Column="1"
                                    SelectedDate="{Binding StartDate}"
                                    Margin="10,0"/>
                        <DatePicker Grid.Column="2"
                                    SelectedDate="{Binding EndDate}"
                                    Margin="10,0,0,0"/>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№"
                                                Binding="{Binding OrderID}"
                                                Width="50"/>
                            <DataGridTextColumn Header="Клієнт"
                                                Binding="{Binding CustomerName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Телефон"
                                                Binding="{Binding CustomerPhone}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Дата"
                                                Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Сума"
                                                Binding="{Binding TotalAmount, StringFormat={}{0:C}}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Статус"
                                                Binding="{Binding Status}"
                                                Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ПОСТАЧАЛЬНИКИ -->
            <TabItem Header="🏢 Постачальники"
                     x:Name="SuppliersTab">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <Button Content="🔄 Оновити"
                                Command="{Binding RefreshCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="➕ Додати"
                                Command="{Binding AddSupplierCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="✏️ Редагувати"
                                Command="{Binding EditSupplierCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="🗑️ Видалити"
                                Command="{Binding DeleteSupplierCommand}"
                                Padding="10,5"
                                Margin="5,0"/>
                        <Button Content="📊 Звіти"
                                Click="OpenReports_Click"
                                Padding="10,5"
                                Margin="20,0,0,0"
                                Background="#4CAF50"
                                Foreground="White"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10"
                             Height="30"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding SupplierID}"
                                                Width="50"/>
                            <DataGridTextColumn Header="Назва"
                                                Binding="{Binding CompanyName}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Контактна особа"
                                                Binding="{Binding ContactPerson}"
                                                Width="150"/>
                            <DataGridTextColumn Header="Телефон"
                                                Binding="{Binding Phone}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Email"
                                                Binding="{Binding Email}"
                                                Width="180"/>
                            <DataGridTextColumn Header="Адреса"
                                                Binding="{Binding Address}"
                                                Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
