<Window x:Class="PetStoreDesktop.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PetStoreDesktop.Views"
        xmlns:vm="clr-namespace:PetStoreDesktop.ViewModels"
        xmlns:conv="clr-namespace:PetStoreDesktop.Converters"
        mc:Ignorable="d"
        Title="{Binding Product.ProductID, Converter={StaticResource IdToWindowTitleConverter}}"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:IdToWindowTitleConverter x:Key="IdToWindowTitleConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поля для редагування -->
        <ScrollViewer Grid.Row="0"
                VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,20">
                <!-- Базова інформація -->
                <GroupBox Header="Базова інформація"
                        Margin="0,0,0,15">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0"
                                Grid.Column="0"
                                Content="Назва товару*:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0"
                                Grid.Column="1"
                                 Text="{Binding Product.ProductName, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="5"/>

                        <Label Grid.Row="1"
                                Grid.Column="0"
                                Content="Опис:"
                                VerticalAlignment="Top"/>
                        <TextBox Grid.Row="1"
                                Grid.Column="1"
                                 Text="{Binding Product.Description}"
                                 Height="60"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                 Margin="5"
                                VerticalScrollBarVisibility="Auto"/>

                        <Label Grid.Row="2"
                                Grid.Column="0"
                                Content="Ціна* (грн):"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2"
                                Grid.Column="1"
                                 Text="{Binding Product.Price, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="5"/>

                        <Label Grid.Row="3"
                                Grid.Column="0"
                                Content="Кількість*:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3"
                                Grid.Column="1"
                                 Text="{Binding Product.QuantityInStock, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="5"/>

                        <Label Grid.Row="4"
                                Grid.Column="0"
                                Content="Мін. рівень:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4"
                                Grid.Column="1"
                                 Text="{Binding Product.ReorderLevel}"
                                 Margin="5"/>

                        <Label Grid.Row="5"
                                Grid.Column="0"
                                Content="Одиниця:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5"
                                Grid.Column="1"
                                 Text="{Binding Product.Unit}"
                                 Margin="5"/>
                    </Grid>
                </GroupBox>

                <!-- Додаткові параметри -->
                <GroupBox Header="Додаткові параметри"
                        Margin="0,0,0,15">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0"
                                Grid.Column="0"
                                Content="Вага (кг):"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0"
                                Grid.Column="1"
                                 Text="{Binding Product.Weight, StringFormat=F3}"
                                 Margin="5"/>

                        <Label Grid.Row="1"
                                Grid.Column="0"
                                Content="Розміри:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1"
                                Grid.Column="1"
                                 Text="{Binding Product.Dimensions}"
                                 Margin="5"/>

                        <Label Grid.Row="2"
                                Grid.Column="0"
                                Content="SKU:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2"
                                Grid.Column="1"
                                 Text="{Binding Product.SKU}"
                                 Margin="5"/>

                        <Label Grid.Row="3"
                                Grid.Column="0"
                                Content="Активний:"
                                VerticalAlignment="Center"/>
                        <CheckBox Grid.Row="3"
                                Grid.Column="1"
                                  IsChecked="{Binding Product.IsActive}"
                                  VerticalAlignment="Center"
                                Margin="5"/>
                    </Grid>
                </GroupBox>

                <!-- Категорія та постачальник -->
                <GroupBox Header="Категорія та постачальник"
                        Margin="0,0,0,15">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0"
                                Grid.Column="0"
                                Content="Категорія:"
                                VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="0"
                                Grid.Column="1"
                                  ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding Product.Category}"
                                  DisplayMemberPath="CategoryName"
                                  Margin="5"/>

                        <Label Grid.Row="1"
                                Grid.Column="0"
                                Content="Постачальник:"
                                VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="1"
                                Grid.Column="1"
                                  ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding Product.Supplier}"
                                  DisplayMemberPath="CompanyName"
                                  Margin="5"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Повідомлення про помилку -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="0,0,0,10"
                   TextWrapping="Wrap"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
            <Button Content="💾 Зберегти"
                    Command="{Binding SaveCommand}"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            <Button Content="❌ Скасувати"
                    Command="{Binding CancelCommand}"
                    Padding="15,8"/>
        </StackPanel>
    </Grid>
</Window>
