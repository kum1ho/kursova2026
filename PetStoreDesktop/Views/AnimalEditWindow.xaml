<Window x:Class="PetStoreDesktop.Views.AnimalEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редагування тварини"
        Height="550"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

        <Grid Margin="20">
                <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0"
                                VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                                <!-- Основна інформація -->
                                <GroupBox Header="Основна інформація"
                                                Margin="0,0,0,15">
                                        <Grid Margin="10">
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0"
                                                                Content="Ім'я тварини:*"
                                                                VerticalAlignment="Center"/>
                                                <TextBox Grid.Row="0"
                                                                Grid.Column="1"
                                                                Text="{Binding Animal.Name}"
                                                                Margin="0,5"/>

                                                <Label Grid.Row="1"
                                                                Content="Вид:*"
                                                                VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="1"
                                                                Grid.Column="1"
                                                          Text="{Binding Animal.Species}"
                                                          IsEditable="True"
                                                          Margin="0,5">
                                                        <ComboBoxItem Content="Кіт"/>
                                                        <ComboBoxItem Content="Собака"/>
                                                        <ComboBoxItem Content="Папуга"/>
                                                        <ComboBoxItem Content="Хом'як"/>
                                                        <ComboBoxItem Content="Кролик"/>
                                                        <ComboBoxItem Content="Риба"/>
                                                        <ComboBoxItem Content="Черепаха"/>
                                                </ComboBox>

                                                <Label Grid.Row="2"
                                                                Content="Порода:"
                                                                VerticalAlignment="Center"/>
                                                <TextBox Grid.Row="2"
                                                                Grid.Column="1"
                                                                Text="{Binding Animal.Breed}"
                                                                Margin="0,5"/>

                                                <Label Grid.Row="3"
                                                                Content="Вік (місяців):"
                                                                VerticalAlignment="Center"/>
                                                <TextBox Grid.Row="3"
                                                                Grid.Column="1"
                                                                Text="{Binding Animal.AgeMonths}"
                                                                Margin="0,5"/>

                                                <Label Grid.Row="4"
                                                                Content="Стать:"
                                                                VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="4"
                                                                Grid.Column="1"
                                                          Text="{Binding Animal.Gender}"
                                                          IsEditable="True"
                                                          Margin="0,5">
                                                        <ComboBoxItem Content="Самець"/>
                                                        <ComboBoxItem Content="Самка"/>
                                                </ComboBox>
                                        </Grid>
                                </GroupBox>

                                <!-- Здоров'я та вакцинація -->
                                <GroupBox Header="Здоров'я"
                                                Margin="0,0,0,15">
                                        <Grid Margin="10">
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0"
                                                                Content="Стан здоров'я:"
                                                                VerticalAlignment="Top"/>
                                                <TextBox Grid.Row="0"
                                                                Grid.Column="1"
                                                         Text="{Binding Animal.HealthStatus}"
                                                         Height="60"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Margin="0,5"/>

                                                <Label Grid.Row="1"
                                                                Content="Вакциновано:"
                                                                VerticalAlignment="Center"/>
                                                <CheckBox Grid.Row="1"
                                                                Grid.Column="1"
                                                          IsChecked="{Binding Animal.IsVaccinated}"
                                                          Content="Так"
                                                          VerticalAlignment="Center"
                                                          Margin="0,5"/>
                                        </Grid>
                                </GroupBox>

                                <!-- Комерційна інформація -->
                                <GroupBox Header="Комерційна інформація"
                                                Margin="0,0,0,15">
                                        <Grid Margin="10">
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="140"/>
                                                        <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0"
                                                                Content="Ціна (грн):*"
                                                                VerticalAlignment="Center"/>
                                                <TextBox Grid.Row="0"
                                                                Grid.Column="1"
                                                                Text="{Binding Animal.Price}"
                                                                Margin="0,5"/>

                                                <Label Grid.Row="1"
                                                                Content="Категорія:"
                                                                VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="1"
                                                                Grid.Column="1"
                                                          ItemsSource="{Binding Categories}"
                                                          SelectedValue="{Binding Animal.CategoryID}"
                                                          DisplayMemberPath="CategoryName"
                                                          SelectedValuePath="CategoryID"
                                                          Margin="0,5"/>

                                                <Label Grid.Row="2"
                                                                Content="Постачальник:"
                                                                VerticalAlignment="Center"/>
                                                <ComboBox Grid.Row="2"
                                                                Grid.Column="1"
                                                          ItemsSource="{Binding Suppliers}"
                                                          SelectedValue="{Binding Animal.SupplierID}"
                                                          DisplayMemberPath="CompanyName"
                                                          SelectedValuePath="SupplierID"
                                                          Margin="0,5"/>

                                                <Label Grid.Row="3"
                                                                Content="Опис:"
                                                                VerticalAlignment="Top"/>
                                                <TextBox Grid.Row="3"
                                                                Grid.Column="1"
                                                         Text="{Binding Animal.Description}"
                                                         Height="80"
                                                         TextWrapping="Wrap"
                                                         AcceptsReturn="True"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Margin="0,5"/>
                                        </Grid>
                                </GroupBox>
                        </StackPanel>
                </ScrollViewer>

                <!-- Кнопки -->
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,15,0,0">
                        <Button Content="💾 Зберегти"
                                Click="Save_Click"
                                Width="120"
                                Height="35"
                                Margin="0,0,10,0"
                                Background="#4CAF50"
                                Foreground="White"
                                FontWeight="Bold"/>
                        <Button Content="❌ Скасувати"
                                Click="Cancel_Click"
                                Width="120"
                                Height="35"
                                Background="#F44336"
                                Foreground="White"
                                FontWeight="Bold"/>
                </StackPanel>
        </Grid>
</Window>
