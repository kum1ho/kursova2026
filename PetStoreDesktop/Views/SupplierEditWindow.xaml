<Window x:Class="PetStoreDesktop.Views.SupplierEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Редагування постачальника"
        Height="500"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Інформація про постачальника"
                        Margin="0,0,0,15">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0"
                                Content="Назва компанії:*"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0"
                                Grid.Column="1"
                                Text="{Binding Supplier.CompanyName}"
                                Margin="0,5"/>

                        <Label Grid.Row="1"
                                Content="Контактна особа:*"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1"
                                Grid.Column="1"
                                Text="{Binding Supplier.ContactPerson}"
                                Margin="0,5"/>

                        <Label Grid.Row="2"
                                Content="Телефон:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="2"
                                Grid.Column="1"
                                Text="{Binding Supplier.Phone}"
                                Margin="0,5"/>

                        <Label Grid.Row="3"
                                Content="Email:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="3"
                                Grid.Column="1"
                                Text="{Binding Supplier.Email}"
                                Margin="0,5"/>

                        <Label Grid.Row="4"
                                Content="Адреса:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="4"
                                Grid.Column="1"
                                Text="{Binding Supplier.Address}"
                                Margin="0,5"/>

                        <Label Grid.Row="5"
                                Content="Місто:"
                                VerticalAlignment="Center"/>
                        <TextBox Grid.Row="5"
                                Grid.Column="1"
                                Text="{Binding Supplier.City}"
                                Margin="0,5"/>

                        <Label Grid.Row="6"
                                Content="Країна:"
                                VerticalAlignment="Center"/>
                        <ComboBox Grid.Row="6"
                                Grid.Column="1"
                                  Text="{Binding Supplier.Country}"
                                  IsEditable="True"
                                  Margin="0,5">
                            <ComboBoxItem Content="Україна"/>
                            <ComboBoxItem Content="Польща"/>
                            <ComboBoxItem Content="Німеччина"/>
                            <ComboBoxItem Content="США"/>
                            <ComboBoxItem Content="Китай"/>
                        </ComboBox>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="💾 Зберегти"
                    Click="Save_Click"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#4CAF50"
                    Foreground="White"
                    FontWeight="Bold"/>
            <Button Content="❌ Скасувати"
                    Click="Cancel_Click"
                    Width="120"
                    Height="35"
                    Background="#F44336"
                    Foreground="White"
                    FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
