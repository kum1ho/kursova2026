<Window x:Class="PetStoreDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PetStoreDesktop.ViewModels"
        xmlns:conv="clr-namespace:PetStoreDesktop.Converters"
        Title="–°–Є—Б—В–µ–Љ–∞ —Г–њ—А–∞–≤–ї—Ц–љ–љ—П –Ј–Њ–Њ–Љ–∞–≥–∞–Ј–Є–љ–Њ–Љ PetStore" Height="750" Width="1300"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    
    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:BooleanToLoadingTextConverter x:Key="BooleanToLoadingTextConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2196F3" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="н∞Њ PetStore" FontSize="24" FontWeight="Bold" Foreground="White" 
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock Text="–°–Є—Б—В–µ–Љ–∞ —Г–њ—А–∞–≤–ї—Ц–љ–љ—П –Ј–Њ–Њ–Љ–∞–≥–∞–Ј–Є–љ–Њ–Љ" FontSize="16" Foreground="White" 
                           VerticalAlignment="Center"/>
                <Button Content="н≥К –Ч–≤—Ц—В–Є" Click="OpenReports_Click" 
                        Padding="15,8" Margin="30,0,0,0" 
                        Background="#4CAF50" Foreground="White"
                        BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" x:Name="MainTabControl" Margin="10">
            <!-- –Т–Ї–ї–∞–і–Ї–∞ 1: –Ф–∞—И–±–Њ—А–і -->
            <TabItem Header="н≥К –Ф–∞—И–±–Њ—А–і">
                <TabItem.DataContext>
                    <vm:DashboardViewModel/>
                </TabItem.DataContext>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="–Ч–∞–≥–∞–ї—М–љ–∞ —Б—В–∞—В–Є—Б—В–Є–Ї–∞" FontSize="20" FontWeight="Bold" 
                                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                            <Button Content="ніД –Ю–љ–Њ–≤–Є—В–Є" Command="{Binding RefreshCommand}" 
                                    Padding="10,5"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="1" Rows="2" Columns="3" Margin="0,0,0,20">
                            <Border Background="#4CAF50" Padding="20" Margin="5" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="–Ґ–Њ–≤–∞—А–Є" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalProducts}" FontSize="32" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="–Р–Ї—В–Є–≤–љ—Ц —В–Њ–≤–∞—А–Є" FontSize="12" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#2196F3" Padding="20" Margin="5" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="–Ґ–≤–∞—А–Є–љ–Є" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalAnimals}" FontSize="32" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="–Т –љ–∞—П–≤–љ–Њ—Б—В—Ц" FontSize="12" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FF9800" Padding="20" Margin="5" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="–Ч–∞–Љ–Њ–≤–ї–µ–љ–љ—П" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalOrders}" FontSize="32" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="–Т—Б—М–Њ–≥–Њ" FontSize="12" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#9C27B0" Padding="20" Margin="5" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="–Ф–Њ—Е—Ц–і" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding TotalRevenueFormatted}" FontSize="28" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="–Ч–∞–≥–∞–ї—М–љ–Є–є" FontSize="12" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F44336" Padding="20" Margin="5" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="–Э–Є–Ј—М–Ї–Є–є –Ј–∞–њ–∞—Б" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LowStockProducts}" FontSize="32" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="–Я–Њ—В—А–µ–±—Г—О—В—М –њ–Њ–њ–Њ–≤–љ–µ–љ–љ—П" FontSize="12" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#795548" Padding="20" Margin="5" CornerRadius="5">
                                <StackPanel>
                                    <TextBlock Text="–Т –Њ–±—А–Њ–±—Ж—Ц" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding PendingOrders}" FontSize="32" Foreground="White" FontWeight="Bold"/>
                                    <TextBlock Text="–Ю—З—Ц–Ї—Г—О—В—М" FontSize="12" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <GroupBox Grid.Column="0" Header="–Ґ–Њ–њ-5 —В–Њ–≤–∞—А—Ц–≤ –Ј–∞ –Љ—Ц—Б—П—Ж—М" Margin="0,0,10,0">
                                <DataGrid ItemsSource="{Binding TopProducts}" 
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="–Ґ–Њ–≤–∞—А" Binding="{Binding ProductName}" Width="*"/>
                                        <DataGridTextColumn Header="–Я—А–Њ–і–∞–љ–Њ" Binding="{Binding TotalQuantitySold}" Width="80"/>
                                        <DataGridTextColumn Header="–Ф–Њ—Е—Ц–і" Binding="{Binding DisplayRevenue}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>

                            <GroupBox Grid.Column="1" Header="–Ю—Б—В–∞–љ–љ—Ц –Ј–∞–Љ–Њ–≤–ї–µ–љ–љ—П" Margin="10,0,0,0">
                                <DataGrid ItemsSource="{Binding RecentOrders}" 
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="вДЦ" Binding="{Binding OrderID}" Width="50"/>
                                        <DataGridTextColumn Header="–Ъ–ї—Ц—Ф–љ—В" Binding="{Binding CustomerName}" Width="*"/>
                                        <DataGridTextColumn Header="–°—Г–Љ–∞" Binding="{Binding TotalAmount, StringFormat=F2}" Width="80"/>
                                        <DataGridTextColumn Header="–°—В–∞—В—Г—Б" Binding="{Binding Status}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- –Т–Ї–ї–∞–і–Ї–∞ 2: –Ґ–Њ–≤–∞—А–Є (–њ–Њ–њ–µ—А–µ–і–љ—Ц–є –≤–Љ—Ц—Б—В) -->
            <TabItem Header="н≥¶ –Ґ–Њ–≤–∞—А–Є">
                <TabItem.DataContext>
                    <vm:MainViewModel/>
                </TabItem.DataContext>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="–£–њ—А–∞–≤–ї—Ц–љ–љ—П —В–Њ–≤–∞—А–∞–Љ–Є" FontSize="18" FontWeight="Bold" 
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="ніД –Ю–љ–Њ–≤–Є—В–Є" Command="{Binding RefreshCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="вЮХ –Ф–Њ–і–∞—В–Є" Command="{Binding AddProductCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="вЬПпЄП –†–µ–і–∞–≥—Г–≤–∞—В–Є" Command="{Binding EditProductCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="нЈСпЄП –Т–Є–і–∞–ї–Є—В–Є" Command="{Binding DeleteProductCommand}" Padding="10,5" Margin="5,0"/>
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="–§—Ц–ї—М—В—А–Є" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="CategoryName" Margin="0,0,10,0"/>
                            <Button Grid.Column="2" Content="–Ю—З–Є—Б—В–Є—В–Є" Command="{Binding ClearFilterCommand}" Padding="10,5"/>
                        </Grid>
                    </GroupBox>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#F0F0F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProductID}" Width="50"/>
                            <DataGridTextColumn Header="–Э–∞–Ј–≤–∞" Binding="{Binding ProductName}" Width="200"/>
                            <DataGridTextColumn Header="–¶—Ц–љ–∞" Binding="{Binding DisplayPrice}" Width="80"/>
                            <DataGridTextColumn Header="–Ъ—Ц–ї—М–Ї—Ц—Б—В—М" Binding="{Binding QuantityInStock}" Width="80"/>
                            <DataGridTextColumn Header="–Ъ–∞—В–µ–≥–Њ—А—Ц—П" Binding="{Binding CategoryName}" Width="120"/>
                            <DataGridTextColumn Header="–Я–Њ—Б—В–∞—З–∞–ї—М–љ–Є–Ї" Binding="{Binding SupplierName}" Width="150"/>
                            <DataGridCheckBoxColumn Header="–Р–Ї—В–Є–≤–љ–Є–є" Binding="{Binding IsActive}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StatusBar Grid.Row="3">
                        <StatusBarItem>
                            <TextBlock><Run Text="–Ґ–Њ–≤–∞—А—Ц–≤: "/><Run Text="{Binding Products.Count}" FontWeight="Bold"/></TextBlock>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- –Т–Ї–ї–∞–і–Ї–∞ 3: –Ґ–≤–∞—А–Є–љ–Є -->
            <TabItem Header="н∞Х –Ґ–≤–∞—А–Є–љ–Є">
                <TabItem.DataContext>
                    <vm:AnimalsViewModel/>
                </TabItem.DataContext>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="–£–њ—А–∞–≤–ї—Ц–љ–љ—П —В–≤–∞—А–Є–љ–∞–Љ–Є" FontSize="18" FontWeight="Bold" 
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="ніД –Ю–љ–Њ–≤–Є—В–Є" Command="{Binding RefreshCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="вЮХ –Ф–Њ–і–∞—В–Є" Command="{Binding AddAnimalCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="вЬПпЄП –†–µ–і–∞–≥—Г–≤–∞—В–Є" Command="{Binding EditAnimalCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="нЈСпЄП –Т–Є–і–∞–ї–Є—В–Є" Command="{Binding DeleteAnimalCommand}" Padding="10,5" Margin="5,0"/>
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="–§—Ц–ї—М—В—А–Є" Margin="0,0,0,10">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding SpeciesList}"
                                      SelectedItem="{Binding SelectedSpecies}" Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      DisplayMemberPath="CategoryName" Margin="0,0,10,0"/>
                            <Button Grid.Column="3" Content="–Ю—З–Є—Б—В–Є—В–Є" Command="{Binding ClearFilterCommand}" Padding="10,5"/>
                        </Grid>
                    </GroupBox>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Animals}"
                              SelectedItem="{Binding SelectedAnimal}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#F0F0F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding AnimalID}" Width="50"/>
                            <DataGridTextColumn Header="–Ж–Љ'—П" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="–Т–Є–і" Binding="{Binding Species}" Width="100"/>
                            <DataGridTextColumn Header="–Я–Њ—А–Њ–і–∞" Binding="{Binding Breed}" Width="150"/>
                            <DataGridTextColumn Header="–Т—Ц–Ї (–Љ—Ц—Б)" Binding="{Binding AgeMonths}" Width="80"/>
                            <DataGridTextColumn Header="–¶—Ц–љ–∞" Binding="{Binding Price, StringFormat=F2}" Width="80"/>
                            <DataGridCheckBoxColumn Header="–Т–∞–Ї—Ж–Є–љ–∞—Ж—Ц—П" Binding="{Binding IsVaccinated}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StatusBar Grid.Row="3">
                        <StatusBarItem>
                            <TextBlock><Run Text="–Ґ–≤–∞—А–Є–љ: "/><Run Text="{Binding Animals.Count}" FontWeight="Bold"/></TextBlock>
                        </StatusBarItem>
                    </StatusBar>
                </Grid>
            </TabItem>

            <!-- –Т–Ї–ї–∞–і–Ї–∞ 4: –Ч–∞–Љ–Њ–≤–ї–µ–љ–љ—П -->
            <TabItem Header="нїТ –Ч–∞–Љ–Њ–≤–ї–µ–љ–љ—П">
                <TabItem.DataContext>
                    <vm:OrdersViewModel/>
                </TabItem.DataContext>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="–£–њ—А–∞–≤–ї—Ц–љ–љ—П –Ј–∞–Љ–Њ–≤–ї–µ–љ–љ—П–Љ–Є" FontSize="18" FontWeight="Bold" 
                                   VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="ніД –Ю–љ–Њ–≤–Є—В–Є" Command="{Binding RefreshCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="вЮХ –°—В–≤–Њ—А–Є—В–Є" Command="{Binding CreateOrderCommand}" Padding="10,5" Margin="5,0"
                                Background="#4CAF50" Foreground="White"/>
                        <Button Content="н≥Э –Ч–Љ—Ц–љ–Є—В–Є —Б—В–∞—В—Г—Б" Command="{Binding ChangeStatusCommand}" Padding="10,5" Margin="5,0"/>
                        <Button Content="нЈСпЄП –Т–Є–і–∞–ї–Є—В–Є" Command="{Binding DeleteOrderCommand}" Padding="10,5" Margin="5,0"/>
                    </StackPanel>

                    <GroupBox Grid.Row="1" Header="–§—Ц–ї—М—В—А–Є" Margin="0,0,0,10">
                        <StackPanel Margin="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,10,0"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding StatusList}"
                                          SelectedItem="{Binding SelectedStatus}" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="–Ю—З–Є—Б—В–Є—В–Є" Command="{Binding ClearFilterCommand}" Padding="10,5"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="–Я–µ—А—Ц–Њ–і:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,10,0" Width="120"/>
                                <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <DatePicker SelectedDate="{Binding EndDate}" Width="120"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding Orders}"
                              SelectedItem="{Binding SelectedOrder}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#F0F0F0" Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="вДЦ" Binding="{Binding OrderID}" Width="60"/>
                            <DataGridTextColumn Header="–Ъ–ї—Ц—Ф–љ—В" Binding="{Binding CustomerName}" Width="200"/>
                            <DataGridTextColumn Header="–Ґ–µ–ї–µ—Д–Њ–љ" Binding="{Binding CustomerPhone}" Width="120"/>
                            <DataGridTextColumn Header="–Ф–∞—В–∞" Binding="{Binding OrderDate, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                            <DataGridTextColumn Header="–°—Г–Љ–∞" Binding="{Binding TotalAmount, StringFormat=F2}" Width="100"/>
                            <DataGridTextColumn Header="–°—В–∞—В—Г—Б" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="3" Text="–Ф–µ—В–∞–ї—Ц –Ј–∞–Љ–Њ–≤–ї–µ–љ–љ—П:" FontWeight="Bold" Margin="0,0,0,5"/>

                    <DataGrid Grid.Row="4" ItemsSource="{Binding SelectedOrderDetails}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#F0F0F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="–Ґ–Њ–≤–∞—А/–Ґ–≤–∞—А–Є–љ–∞" Width="250">
                                <DataGridTextColumn.Binding>
                                    <MultiBinding StringFormat="{}{0}{1}">
                                        <Binding Path="Product.ProductName" TargetNullValue=""/>
                                        <Binding Path="Animal.Name" TargetNullValue=""/>
                                    </MultiBinding>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="–Ъ—Ц–ї—М–Ї—Ц—Б—В—М" Binding="{Binding Quantity}" Width="80"/>
                            <DataGridTextColumn Header="–¶—Ц–љ–∞" Binding="{Binding UnitPrice, StringFormat=F2}" Width="80"/>
                            <DataGridTextColumn Header="–Ч–љ–Є–ґ–Ї–∞ %" Binding="{Binding Discount, StringFormat=F2}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
