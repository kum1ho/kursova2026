<Application x:Class="PetStoreDesktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PetStoreDesktop"
             xmlns:conv="clr-namespace:PetStoreDesktop.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:BooleanToLoadingTextConverter x:Key="BooleanToLoadingTextConverter"/>
        <conv:IdToWindowTitleConverter x:Key="IdToWindowTitleConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Application.Resources>
</Application>
